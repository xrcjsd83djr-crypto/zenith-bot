{
  "name": "@workspace/zenith-bot",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.mjs",
    "build": "esbuild src/index.ts --bundle --platform=node --target=node22 --outfile=dist/index.mjs --format=esm --sourcemap --packages=external",
    "deploy-commands": "tsx src/deploy-commands.ts"
  },
  "dependencies": {
    "@libsql/client": "^0.14.0",
    "discord.js": "^14.16.3",
    "drizzle-orm": "^0.45.2",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "esbuild": "0.27.3",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3"
  }
}
